# REQUIRED: where your Obsidian vault lives on the host.
VAULT_HOST_PATH=/Users/you/Documents/Obsidian/MyVault

# Optional external API keys
GOOGLE_PLACES_API_KEY=
MAPBOX_PUBLIC_TOKEN=

# Google Maps JS map provider (Settings → Map provider → Google).
# This key is exposed to the browser, so restrict it by HTTP referrer in
# Google Cloud Console. Can be the same key as GOOGLE_PLACES_API_KEY only
# if you've set referrer restrictions; otherwise use a separate key.
GOOGLE_MAPS_PUBLIC_KEY=

# Apple MapKit JS — two paths, pick ONE:
#
#  (a) Long-term (Apple Developer Program required) — set all three. The
#      private key is the contents of your .p8 file; \n escape sequences are
#      accepted for single-line env values. Server signs short-lived JWTs.
APPLE_MAPKIT_TEAM_ID=
APPLE_MAPKIT_KEY_ID=
APPLE_MAPKIT_PRIVATE_KEY=
#
#  (b) Quick start — paste a pre-signed JWT from
#      https://maps.developer.apple.com/token-maker. No private-key signing
#      happens server-side; you must rotate this manually before it expires
#      (Apple defaults to 7 days for browser tokens). Takes precedence over
#      the three vars above when set.
APPLE_MAPKIT_TOKEN=

# Vault location inside the container. Usually leave these as-is.
VAULT_PATH=/data
VAULT_SUBDIR=Restaurants

# Obsidian deep links (optional)
# Set to your vault's display name so "Open in Obsidian" buttons can resolve.
OBSIDIAN_VAULT_NAME=

# App
PORT=3000
LOG_LEVEL=info

# Optional Docker image override for docker-compose.yml
# Default is adamxbot/restauranteer:latest from Docker Hub.
# RESTAURANTEER_IMAGE=adamxbot/restauranteer:latest
