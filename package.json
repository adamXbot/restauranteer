    "@types/node": "^25.9.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
